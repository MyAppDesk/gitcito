{
  "name": "gitcito",
  "productName": "Gitcito",
  "version": "1.16.2",
  "description": "A lightweight Git client built with Electron, React and clean architecture",
  "main": "out/main/index.js",
  "license": "MIT",
  "author": "MyAppDesk <team@myappdesk.dev>",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "release": "npm run build && electron-builder --publish always",
    "release:patch": "release-it --increment patch",
    "release:minor": "release-it --increment minor",
    "release:major": "release-it --increment major",
    "preview": "electron-vite preview",
    "playground": "bash examples/setup-playground.sh",
    "playground:rebuild": "PLAYGROUND_FORCE=1 bash examples/setup-playground.sh",
    "screenshots:gif": "node examples/screenshots/capture.mjs --gif",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "postinstall": "electron-rebuild -f -w node-pty || true",
    "prepare": "husky"
  },
  "build": {
    "appId": "com.gitcito.desktop",
    "productName": "Gitcito",
    "files": [
      "out/**/*",
      "resources/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "MyAppDesk",
      "repo": "gitcito"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Development",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "@fontsource/nunito": "^5.2.7",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "dompurify": "^3.4.10",
    "electron-updater": "^6.8.9",
    "framer-motion": "^11.11.9",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.453.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.27.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.5"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@electron/rebuild": "^3.6.0",
    "@release-it/conventional-changelog": "^8.0.1",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^31.7.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "husky": "^9.1.7",
    "playwright": "^1.61.0",
    "release-it": "^17.1.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vitest": "^2.1.9"
  }
}
